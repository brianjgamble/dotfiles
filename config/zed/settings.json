              "prompt_cache_key": false,
              "chat_completions": true,
            },
          },
        ],
      },
    },
  },
  "agent": {
    "default_profile": "write",
    "default_model": {
      "provider": "llama.cpp",
      "model": "ggml-org/gemma-4-E4B-it-GGUF:Q8",
      "enable_thinking": false,
    },
    "message_editor_min_lines": 10,
    "use_modifier_to_send": true,
    "inline_assistant_model": {
      "provider": "llama.cpp-autocomplete",
      "model": "ggml-org/Qwen2.5-Coder-1.5B-Q8_0-GGUF:Q8_0",
      "enable_thinking": false,
    },
    "favorite_models": [],
    "model_parameters": [],
  },
  "agent_servers": {
    "claude-acp": {
      "default_config_options": {
        "model": "default",
      },
      "type": "registry",
    },
  },
  "base_keymap": "SublimeText",
  "edit_predictions": {
    "mode": "subtle",
  },
  "format_on_save": "on",
  "buffer_font_family": "Courier Prime Code",
  "buffer_font_size": 15,
  "git_panel": {
    "dock": "right",
  },
  "icon_theme": "Catppuccin Frappé",
  "file_finder": {
    "modal_max_width": "medium",
  },
  "languages": {
    "Markdown": {
      "indent_guides": {
        "background_coloring": "indent_aware",
        "coloring": "indent_aware",
      },
    },
    "C++": {
      "format_on_save": "on",
      "tab_size": 2,
    },
    "Elixir": {
      "language_servers": ["elixir-ls"],
      "format_on_save": "on",
    },
    "HEEx": {
      "language_servers": ["elixir-ls"],
      "format_on_save": "on",
    },
    "Lua": {
      "language_servers": ["pico8-ls"],
      "format_on_save": "on",
    },
  },
  "lsp": {
    "clangd": {
      "binary": {
        "arguments": ["-background-index", "-compile-commands-dir=build"],
      },
    },
    "hls": {
      "initialization_options": {
        "haskell": {
          "cabalFormattingProvider": "cabal-gild",
          "formattingProvider": "fourmolu",
        },
      },
    },
  },
  "tab_size": 2,
  "tabs": {
    "close_position": "left",
    "file_icons": true,
    "git_status": true,
    "show_close_button": "always",
    "show_diagnostics": "errors",
  },
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  "terminal": {
    "font_size": 14,
  },
  "theme": "Gentle Dark",
  "ui_font_size": 16,
  "vim_mode": false,
}
