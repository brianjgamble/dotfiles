            "capabilities": {
              "tools": true,
              "images": false,
              "parallel_tool_calls": true,
              "prompt_cache_key": false,
              "chat_completions": true,
            },
          },
          {
            "name": "Qwen/Qwen2.5-Coder-14B-Instruct-GGUF:Q5_K_M",
            "display_name": "Qwen2.5-Coder-14B-Instruct",
            "max_tokens": 32768,
            "max_output_tokens": 8192,
            "max_completion_tokens": 8192,
            "capabilities": {
              "tools": true,
              "images": false,
              "parallel_tool_calls": true,
              "prompt_cache_key": false,
              "chat_completions": true,
            },
          },
        ],
      },
      "llama.cpp-autocomplete": {
        "api_url": "http://localhost:8081/v1",
        "available_models": [
          {
            "name": "ggml-org/Qwen2.5-Coder-1.5B-Q8_0-GGUF:Q8_0",
            "display_name": "Qwen2.5-Coder-1.5B",
            "max_tokens": 4096,
            "max_output_tokens": 1024,
            "max_completion_tokens": 1024,
            "capabilities": {
